<!DOCTYPE html>
<html lang="en">
<head>
    <style>
        .river-card { border-left: 8px solid #3498db; background: #f7fbff; padding: 25px; width: 420px; font-family: 'Segoe UI', sans-serif; }
        .title { color: #2980b9; font-weight: bold; font-size: 1.6em; margin-bottom: 10px; }
        .info { margin: 5px 0; color: #34495e; }
    </style>
</head>
<body>
    <div class="river-card">
        <div class="title">🌊 Sabarmati River</div>
        <p class="info"><strong>Origin:</strong> Aravalli Range, Rajasthan</p>
        <p class="info"><strong>Length:</strong> ~371 km</p>
        <p class="info"><strong>Key City:</strong> Ahmedabad</p>
        <p class="info"><strong>Outflow:</strong> Gulf of Khambhat, Arabian Sea</p>
    </div>
</body>
</html>
